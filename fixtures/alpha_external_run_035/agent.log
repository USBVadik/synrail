e_packages / \"synrail_local_repo.pth\"\n58\t    pth_file.write_text(str(repo_root) + \"\\n\")\n59\t    return pth_file\n60\t\n61\t\n62\tdef install_unix_script(target: Path) -> None:\n63\t    script = textwrap.dedent(\n64\t        f\"\"\"\\\n65\t        #!/bin/sh\n66\t        exec \"{target.parent / 'python'}\" -c 'from alpha import main; raise SystemExit(main())' \"$@\"\n67\t        \"\"\"\n68\t    )\n69\t    target.write_text(script)\n70\t    target.chmod(target.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)\n71\t\n72\t\n73\tdef install_windows_script(target: Path) -> None:\n74\t    script = \"@echo off\\r\\n\\\"%~dp0python.exe\\\" -c \\\"from alpha import main; raise SystemExit(main())\\\" %*\\r\\n\"\n75\t    target.write_text(script)\n76\t\n77\t\n78\tdef install_synrail_script(venv_root: Path) -> Path:\n79\t    target = synrail_bin_for_venv(venv_root)\n80\t    target.parent.mkdir(parents=True, exist_ok=True)\n81\t    if is_windows():\n82\t        install_windows_script(target)\n83\t    else:\n84\t        install_unix_script(target)\n85\t    return target\n86\t\n87\t\n88\tdef verify_install(synrail_bin: Path) -> None:\n89\t    subprocess.run(\n90\t        [str(synrail_bin), \"start\", \"--help\"],\n91\t        check=True,\n92\t        capture_output=True,\n93\t        text=True,\n94\t    )\n95\t\n96\t\n97\tdef build_parser() -> argparse.ArgumentParser:\n98\t    parser = argparse.ArgumentParser(description=\"Install the current Synrail alpha lane into a local venv without pip build isolation.\")\n99\t    parser.add_argument(\"--venv\", default=\".venv\", help=\"Virtualenv path to create or reuse. Default: .venv\")\n100\t    parser.add_argument(\n101\t        \"--project-root\",\n102\t        help=\"Optional project root where the freshly installed synrail should immediately run `install-agent-files`.\",\n103\t    )\n104\t    parser.add_argument(\n105\t        \"--force-agent-files\",\n106\t        action=\"store_true\",\n107\t        help=\"If --project-root is set, pass --force to `synrail install-agent-files` after creating the venv.\",\n108\t    )\n109\t    parser.add_argument(\"--skip-verify\", action=\"store_true\", help=\"Skip the final `synrail start --help` verification.\")\n110\t    return parser\n111\t\n112\t\n113\tdef main(argv: list[str] | None = None) -> int:\n114\t    parser = build_parser()\n115\t    args = parser.parse_args(argv)\n116\t\n117\t    repo_root = repo_root_from_script()\n118\t    venv_root = Path(args.venv).resolve()\n119\t    python_bin = ensure_venv(venv_root)\n120\t    site_packages = site_packages_for_python(python_bin)\n121\t    pth_file = install_repo_path(site_packages, repo_root)\n122\t    synrail_bin = install_synrail_script(venv_root)\n123\t\n124\t    if not args.skip_verify:\n125\t        verify_install(synrail_bin)\n126\t\n127\t    project_root: Path | None = None\n128\t    if args.project_root:\n129\t        project_root = Path(args.project_root).resolve()\n130\t        project_root.mkdir(parents=True, exist_ok=True)\n131\t        install_cmd = [\n132\t            str(synrail_bin),\n133\t            \"install-agent-files\",\n134\t            \"--project-root\",\n135\t            str(project_root),\n136\t        ]\n137\t        if args.force_agent_files:\n138\t            install_cmd.append(\"--force\")\n139\t        subprocess.run(\n140\t            install_cmd,\n141\t            check=True,\n142\t            capture_output=False,\n143\t            text=True,\n144\t        )\n145\t\n146\t    rel_venv = os.path.relpath(venv_root, Path.cwd())\n147\t    rel_synrail = os.path.relpath(synrail_bin, Path.cwd())\n148\t    print(\"Synrail alpha install complete.\")\n149\t    print(f\"Virtualenv: {rel_venv}\")\n150\t    print(f\"Repo path linked via: {pth_file}\")\n151\t    print(f\"Command: {rel_synrail}\")\n152\t    if project_root is not None:\n153\t        rel_project = os.path.relpath(project_root, Path.cwd())\n154\t        print(f\"Agent files installed into: {rel_project}\