{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_class",
    "from_state",
    "closure_status",
    "blocking_reason",
    "continuation_allowed",
    "continuation_entrypoint",
    "repair_policy",
    "artifact_quality_hints",
    "required_inputs",
    "runtime_defaults",
    "next_safe_step"
  ],
  "properties": {
    "schema_version": {
      "const": "repair_handoff_v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_class": {
      "type": "string",
      "minLength": 1
    },
    "from_state": {
      "type": "string",
      "minLength": 1
    },
    "closure_status": {
      "type": "string",
      "minLength": 1
    },
    "blocking_reason": {
      "type": "string"
    },
    "continuation_allowed": {
      "type": "boolean"
    },
    "continuation_entrypoint": {
      "type": "string"
    },
    "resumability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "family",
        "active_pressures",
        "recommended_repair_order",
        "requires_new_run",
        "explanation"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "REPAIRABLE",
            "NOT_RESUMABLE"
          ]
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "active_pressures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommended_repair_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requires_new_run": {
          "type": "boolean"
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repair_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_type",
        "next_step_id",
        "ready_now_step_ids",
        "ordered_steps"
      ],
      "properties": {
        "policy_type": {
          "type": "string",
          "minLength": 1
        },
        "next_step_id": {
          "type": "string"
        },
        "ready_now_step_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ordered_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step_id",
              "status",
              "required_inputs",
              "repairs_artifacts",
              "resolves_pressures",
              "why"
            ],
            "properties": {
              "step_id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "minLength": 1
              },
              "required_inputs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "repairs_artifacts": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "resolves_pressures": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "why": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "artifact_quality_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "quality",
          "still_stale_parts",
          "mapped_inputs",
          "repair_step",
          "why"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "quality": {
            "type": "string",
            "enum": [
              "STALE",
              "NON_RESUMABLE"
            ]
          },
          "still_stale_parts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "mapped_inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "repair_step": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          },
          "stale_subsurfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "subsurface_id",
                "status",
                "mapped_inputs",
                "why"
              ],
              "properties": {
                "subsurface_id": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "STALE",
                    "NON_RESUMABLE"
                  ]
                },
                "mapped_inputs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "why": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "input_id",
          "kind",
          "cli_flag",
          "description",
          "required_value"
        ],
        "properties": {
          "input_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "cli_flag": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "required_value": {
            "type": "string"
          }
        }
      }
    },
    "runtime_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "refresh_event_type",
        "refresh_use_bundle",
        "refresh_use_closure"
      ],
      "properties": {
        "refresh_event_type": {
          "type": "string"
        },
        "refresh_use_bundle": {
          "type": "boolean"
        },
        "refresh_use_closure": {
          "type": "boolean"
        }
      }
    },
    "next_safe_step": {
      "type": "string"
    }
  }
}
