{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "internal_cross_repo_pilot_v0.schema.json",
  "title": "Synrail internal cross-repository pilot record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_class",
    "claim_scope",
    "captured_at",
    "run_id",
    "repository",
    "task",
    "timing",
    "outcome",
    "verification_profiles",
    "artifact_bindings",
    "notes"
  ],
  "properties": {
    "schema_version": { "const": "internal_cross_repo_pilot_v0" },
    "evidence_class": { "const": "INTERNAL_CROSS_REPO_DOGFOOD" },
    "claim_scope": { "const": "NOT_EXTERNAL_EMPIRICAL_EVIDENCE" },
    "captured_at": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "revision", "ecosystem"],
      "properties": {
        "label": { "type": "string", "minLength": 1, "maxLength": 200 },
        "revision": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
        "ecosystem": { "type": "string", "minLength": 1, "maxLength": 100 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "class"],
      "properties": {
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "class": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup_seconds",
        "time_to_first_blocker_seconds",
        "verification_seconds",
        "time_to_accepted_seconds",
        "total_operator_seconds"
      ],
      "properties": {
        "setup_seconds": { "type": "number", "minimum": 0 },
        "time_to_first_blocker_seconds": { "type": ["number", "null"], "minimum": 0 },
        "verification_seconds": { "type": "number", "minimum": 0 },
        "time_to_accepted_seconds": { "type": ["number", "null"], "minimum": 0 },
        "total_operator_seconds": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted",
        "closure_status",
        "report_result",
        "report_reason",
        "false_green_prevented",
        "first_blocker_reason",
        "operator_interventions",
        "confusion_moments"
      ],
      "properties": {
        "accepted": { "type": "boolean" },
        "closure_status": { "type": "string", "minLength": 1, "maxLength": 100 },
        "report_result": { "type": "string", "minLength": 1, "maxLength": 100 },
        "report_reason": { "type": "string", "minLength": 1, "maxLength": 200 },
        "false_green_prevented": { "enum": ["yes", "no", "unclear"] },
        "first_blocker_reason": { "type": ["string", "null"], "maxLength": 200 },
        "operator_interventions": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 500 }
        },
        "confusion_moments": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "verification_profiles": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile", "duration_seconds", "exit_code", "green"],
        "properties": {
          "profile": { "type": "string", "minLength": 1, "maxLength": 80 },
          "duration_seconds": { "type": "number", "minimum": 0 },
          "exit_code": { "type": "integer" },
          "green": { "type": "boolean" }
        }
      }
    },
    "artifact_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_sha256",
        "project_profile_sha256",
        "report_sha256",
        "final_result_sha256",
        "verification_receipts_sha256",
        "blocked_report_sha256"
      ],
      "properties": {
        "state_sha256": { "$ref": "#/$defs/hash" },
        "project_profile_sha256": { "$ref": "#/$defs/hash" },
        "report_sha256": { "$ref": "#/$defs/hash" },
        "final_result_sha256": { "$ref": "#/$defs/hash" },
        "verification_receipts_sha256": { "$ref": "#/$defs/hash" },
        "blocked_report_sha256": {
          "oneOf": [{ "$ref": "#/$defs/hash" }, { "type": "null" }]
        }
      }
    },
    "notes": { "type": "string", "maxLength": 4000 }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
