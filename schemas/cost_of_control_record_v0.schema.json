{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synrail.local/schemas/cost_of_control_record_v0.schema.json",
  "title": "Synrail Cost Of Control Record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_count",
    "source_records",
    "provenance_mix",
    "verdict_counts",
    "aggregate_deltas",
    "hotspots",
    "path_buckets",
    "reading"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cost_of_control_record_v0"
    },
    "scenario_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "scenario_id", "scenario_class", "verdict"],
        "properties": {
          "path": {"type": "string"},
          "scenario_id": {"type": "string"},
          "scenario_class": {"type": "string"},
          "verdict": {
            "type": "string",
            "enum": ["SYNRAIL_BETTER", "BASELINE_GOOD_ENOUGH", "UNCLEAR"]
          }
        }
      }
    },
    "provenance_mix": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["curated_local_estimate", "pressure_synthetic", "external_empirical"]
      }
    },
    "verdict_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["SYNRAIL_BETTER", "BASELINE_GOOD_ENOUGH", "UNCLEAR"],
      "properties": {
        "SYNRAIL_BETTER": {"type": "integer", "minimum": 0},
        "BASELINE_GOOD_ENOUGH": {"type": "integer", "minimum": 0},
        "UNCLEAR": {"type": "integer", "minimum": 0}
      }
    },
    "aggregate_deltas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "avg_operator_minutes_added",
        "avg_intervention_count_added",
        "avg_repair_cycles_added",
        "avg_invalidation_count_added",
        "avg_closure_latency_minutes_added",
        "avg_checks_per_accepted_closure_added",
        "avg_false_green_exposure_reduced",
        "avg_artifact_completeness_percent_gain",
        "avg_mandatory_mental_steps_added",
        "avg_trust_bearing_artifacts_added",
        "avg_required_visible_surfaces_added",
        "avg_skippable_visible_surfaces_added",
        "avg_operator_visible_actions_added",
        "avg_got_lost_moments_added",
        "avg_kernel_control_mass_added",
        "avg_behavioral_control_tax_added",
        "avg_fixed_control_mass_added",
        "avg_total_control_burden_added"
      ],
      "properties": {
        "avg_operator_minutes_added": {"type": "integer"},
        "avg_intervention_count_added": {"type": "integer"},
        "avg_repair_cycles_added": {"type": "integer"},
        "avg_invalidation_count_added": {"type": "integer"},
        "avg_closure_latency_minutes_added": {"type": "integer"},
        "avg_checks_per_accepted_closure_added": {"type": "integer"},
        "avg_false_green_exposure_reduced": {"type": "integer"},
        "avg_artifact_completeness_percent_gain": {"type": "integer"},
        "avg_mandatory_mental_steps_added": {"type": "integer"},
        "avg_trust_bearing_artifacts_added": {"type": "integer"},
        "avg_required_visible_surfaces_added": {"type": "integer"},
        "avg_skippable_visible_surfaces_added": {"type": "integer"},
        "avg_operator_visible_actions_added": {"type": "integer"},
        "avg_got_lost_moments_added": {"type": "integer"},
        "avg_kernel_control_mass_added": {"type": "integer"},
        "avg_behavioral_control_tax_added": {"type": "integer"},
        "avg_fixed_control_mass_added": {"type": "integer"},
        "avg_total_control_burden_added": {"type": "integer"}
      }
    },
    "hotspots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "highest_operator_minutes_added",
        "highest_closure_latency_minutes_added",
        "highest_checks_per_accepted_closure_added",
        "highest_false_green_exposure_reduced",
        "highest_artifact_completeness_percent_gain",
        "highest_operator_visible_actions_added",
        "highest_got_lost_moments_added",
        "highest_kernel_control_mass_added",
        "highest_behavioral_control_tax_added",
        "highest_fixed_control_mass_added",
        "highest_total_control_burden_added"
      ],
      "properties": {
        "highest_operator_minutes_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_closure_latency_minutes_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_checks_per_accepted_closure_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_false_green_exposure_reduced": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_artifact_completeness_percent_gain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_operator_visible_actions_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_got_lost_moments_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_kernel_control_mass_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_behavioral_control_tax_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_fixed_control_mass_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        },
        "highest_total_control_burden_added": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "path", "value"],
          "properties": {
            "scenario_id": {"type": "string"},
            "path": {"type": "string"},
            "value": {"type": "integer"}
          }
        }
      }
    },
    "path_buckets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["justified_cost_paths", "baseline_sufficient_paths", "under_proven_paths"],
      "properties": {
        "justified_cost_paths": {
          "type": "array",
          "items": {"type": "string"}
        },
        "baseline_sufficient_paths": {
          "type": "array",
          "items": {"type": "string"}
        },
        "under_proven_paths": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "reading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strongest_justified_path",
        "clearest_overhead_path",
        "everyday_status",
        "hybrid_status",
        "compound_status",
        "focus_task_class",
        "focus_task_class_record_count",
        "focus_task_class_verdict",
        "focus_task_class_stability",
        "focus_task_class_median_operator_minutes_added",
        "focus_task_class_median_closure_latency_minutes_added",
        "focus_task_class_median_checks_per_accepted_closure_added",
        "focus_task_class_median_operator_visible_actions_added",
        "focus_task_class_median_got_lost_moments_added",
        "focus_task_class_median_fixed_control_mass_added",
        "focus_task_class_median_behavioral_control_tax_added",
        "focus_task_class_median_total_control_burden_added",
        "focus_task_class_spread_operator_minutes_added",
        "focus_task_class_spread_closure_latency_minutes_added",
        "focus_task_class_spread_checks_per_accepted_closure_added",
        "focus_task_class_spread_operator_visible_actions_added",
        "focus_task_class_spread_got_lost_moments_added",
        "focus_task_class_spread_fixed_control_mass_added",
        "focus_task_class_spread_behavioral_control_tax_added",
        "focus_task_class_spread_total_control_burden_added",
        "focus_task_class_priority_one_status",
        "focus_task_class_priority_one_barrier",
        "focus_task_class_kernel_cheapness_status",
        "focus_task_class_kernel_cheapness_barrier",
        "focus_task_class_behavior_cheapness_status",
        "focus_task_class_behavior_cheapness_barrier"
      ],
      "properties": {
        "strongest_justified_path": {"type": "string"},
        "clearest_overhead_path": {"type": "string"},
        "everyday_status": {"type": "string"},
        "hybrid_status": {"type": "string"},
        "compound_status": {"type": "string"},
        "primary_scenario_class": {"type": "string"},
        "primary_scenario_class_status": {"type": "string"},
        "focus_task_class": {"type": "string"},
        "focus_task_class_record_count": {"type": "integer", "minimum": 0},
        "focus_task_class_verdict": {"type": "string"},
        "focus_task_class_stability": {"type": "string"},
        "focus_task_class_median_operator_minutes_added": {"type": ["integer", "number"]},
        "focus_task_class_median_closure_latency_minutes_added": {"type": ["integer", "number"]},
        "focus_task_class_median_checks_per_accepted_closure_added": {"type": ["integer", "number"]},
        "focus_task_class_median_operator_visible_actions_added": {"type": ["integer", "number"]},
        "focus_task_class_median_got_lost_moments_added": {"type": ["integer", "number"]},
        "focus_task_class_median_fixed_control_mass_added": {"type": ["integer", "number"]},
        "focus_task_class_median_behavioral_control_tax_added": {"type": ["integer", "number"]},
        "focus_task_class_median_total_control_burden_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_operator_minutes_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_closure_latency_minutes_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_checks_per_accepted_closure_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_operator_visible_actions_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_got_lost_moments_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_fixed_control_mass_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_behavioral_control_tax_added": {"type": ["integer", "number"]},
        "focus_task_class_spread_total_control_burden_added": {"type": ["integer", "number"]},
        "focus_task_class_priority_one_status": {"type": "string"},
        "focus_task_class_priority_one_barrier": {"type": "string"},
        "focus_task_class_kernel_cheapness_status": {"type": "string"},
        "focus_task_class_kernel_cheapness_barrier": {"type": "string"},
        "focus_task_class_behavior_cheapness_status": {"type": "string"},
        "focus_task_class_behavior_cheapness_barrier": {"type": "string"}
      }
    }
  }
}
