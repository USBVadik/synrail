{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synrail.local/schemas/doctor_record_v0.schema.json",
  "title": "Synrail Doctor Record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "doctor_run_id",
    "doctor_level",
    "target_execution_surface",
    "trusted_baseline",
    "intended_run_class",
    "gate_results",
    "coverage",
    "blocking_failure_classes",
    "final_verdict",
    "recommended_next_safe_step"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "doctor_record_v0"
    },
    "doctor_run_id": {
      "type": "string"
    },
    "doctor_level": {
      "type": "string",
      "enum": ["CORE_DOCTOR", "SUPPORT_DOCTOR", "EXACT_RETRY_DOCTOR"]
    },
    "target_execution_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "classification"],
      "properties": {
        "path": {"type": "string"},
        "classification": {"type": "string"},
        "observed_identity": {"type": "string"},
        "expected_identity": {"type": "string"}
      }
    },
    "trusted_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity"],
      "properties": {
        "identity": {"type": "string"}
      }
    },
    "intended_run_class": {
      "type": "string",
      "enum": ["core_probe", "support_run", "exact_retry"]
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_identity",
        "clean_execution_surface",
        "helper_integrity",
        "credential_surface",
        "artifact_viability",
        "prompt_task_identity"
      ],
      "properties": {
        "baseline_identity": {"$ref": "#/$defs/gate"},
        "clean_execution_surface": {"$ref": "#/$defs/gate"},
        "helper_integrity": {"$ref": "#/$defs/gate"},
        "credential_surface": {"$ref": "#/$defs/gate"},
        "artifact_viability": {"$ref": "#/$defs/gate"},
        "prompt_task_identity": {"$ref": "#/$defs/gate"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "doctor_version",
        "coverage_source",
        "corpus_version",
        "coverage_threshold_policy",
        "critical_fail_modes",
        "declared_covered_fail_modes",
        "declared_partial_fail_modes",
        "declared_uncovered_fail_modes",
        "covered_fail_modes",
        "partial_fail_modes",
        "uncovered_fail_modes",
        "measured_case_count",
        "measured_case_match_count",
        "measured_case_problem_count",
        "measured_cases",
        "decision_trace",
        "critical_fail_mode_count",
        "critical_covered_count",
        "critical_missing_fail_modes",
        "critical_modes_without_measured_evidence",
        "critical_modes_with_mismatched_evidence",
        "threshold_met",
        "gate_status",
        "gate_reason"
      ],
      "properties": {
        "schema_version": {"type": "string", "const": "doctor_coverage_record_v0"},
        "doctor_version": {"type": "string"},
        "coverage_source": {"type": "string"},
        "corpus_version": {"type": "string"},
        "coverage_threshold_policy": {"type": "string"},
        "critical_fail_modes": {"type": "array", "items": {"type": "string"}},
        "declared_covered_fail_modes": {"type": "array", "items": {"type": "string"}},
        "declared_partial_fail_modes": {"type": "array", "items": {"type": "string"}},
        "declared_uncovered_fail_modes": {"type": "array", "items": {"type": "string"}},
        "covered_fail_modes": {"type": "array", "items": {"type": "string"}},
        "partial_fail_modes": {"type": "array", "items": {"type": "string"}},
        "uncovered_fail_modes": {"type": "array", "items": {"type": "string"}},
        "measured_case_count": {"type": "integer"},
        "measured_case_match_count": {"type": "integer"},
        "measured_case_problem_count": {"type": "integer"},
        "measured_cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "case_id",
              "fail_mode_id",
              "doctor_record",
              "status",
              "observed_final_verdict",
              "observed_blocking_failure_classes",
              "observed_failing_gate",
              "observed_gate_note",
              "mismatch_reasons"
            ],
            "properties": {
              "case_id": {"type": "string"},
              "fail_mode_id": {"type": "string"},
              "doctor_record": {"type": "string"},
              "status": {"type": "string", "enum": ["MATCHED", "MISMATCHED", "MISSING_EVIDENCE", "INVALID_EVIDENCE"]},
              "observed_final_verdict": {"type": "string"},
              "observed_blocking_failure_classes": {"type": "array", "items": {"type": "string"}},
              "observed_failing_gate": {"type": "string"},
              "observed_gate_note": {"type": "string"},
              "mismatch_reasons": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "decision_trace": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fail_mode_id",
              "is_critical",
              "classification",
              "measured_case_ids",
              "matched_case_ids",
              "problematic_case_ids",
              "gate_effect",
              "why"
            ],
            "properties": {
              "fail_mode_id": {"type": "string"},
              "is_critical": {"type": "boolean"},
              "classification": {"type": "string", "enum": ["COVERED", "PARTIAL", "UNCOVERED"]},
              "measured_case_ids": {"type": "array", "items": {"type": "string"}},
              "matched_case_ids": {"type": "array", "items": {"type": "string"}},
              "problematic_case_ids": {"type": "array", "items": {"type": "string"}},
              "gate_effect": {
                "type": "string",
                "enum": [
                  "SATISFIES_CRITICAL_COVERAGE",
                  "HAS_MISMATCHED_EVIDENCE",
                  "MISSING_MEASURED_EVIDENCE",
                  "NON_CRITICAL"
                ]
              },
              "why": {"type": "string"}
            }
          }
        },
        "critical_fail_mode_count": {"type": "integer"},
        "critical_covered_count": {"type": "integer"},
        "critical_missing_fail_modes": {"type": "array", "items": {"type": "string"}},
        "critical_modes_without_measured_evidence": {"type": "array", "items": {"type": "string"}},
        "critical_modes_with_mismatched_evidence": {"type": "array", "items": {"type": "string"}},
        "threshold_met": {"type": "boolean"},
        "gate_status": {"type": "string", "enum": ["PASS", "BLOCKED"]},
        "gate_reason": {"type": "string"}
      }
    },
    "blocking_failure_classes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "final_verdict": {
      "type": "string"
    },
    "recommended_next_safe_step": {
      "type": "string"
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "note"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "NOT_APPLICABLE"]
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
