{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_class",
    "from_state",
    "resulting_state",
    "result",
    "completed_step_id",
    "completed_artifact_ids",
    "completed_subsurface_ids",
    "remaining_stale_artifact_ids",
    "remaining_stale_subsurface_ids",
    "remaining_non_resumable_artifact_ids",
    "remaining_non_resumable_subsurface_ids",
    "remaining_stale_hints",
    "remaining_non_resumable_hints",
    "next_step_id",
    "ready_now_step_ids",
    "repair_history",
    "resumability",
    "why"
  ],
  "properties": {
    "schema_version": {
      "const": "artifact_repair_receipt_v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_class": {
      "type": "string",
      "minLength": 1
    },
    "from_state": {
      "type": "string",
      "minLength": 1
    },
    "resulting_state": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "STEP_NOT_COMPLETED",
        "NON_RESUMABLE_BOUNDARY_REACHED",
        "STEP_COMPLETED",
        "STEP_PROGRESS_RECORDED"
      ]
    },
    "completed_step_id": {
      "type": "string"
    },
    "completed_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completed_subsurface_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remaining_stale_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remaining_stale_subsurface_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remaining_non_resumable_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remaining_non_resumable_subsurface_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remaining_stale_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "quality",
          "repair_step",
          "still_stale_parts",
          "stale_subsurfaces"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "quality": {
            "const": "STALE"
          },
          "repair_step": {
            "type": "string",
            "minLength": 1
          },
          "still_stale_parts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stale_subsurfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "subsurface_id",
                "why"
              ],
              "properties": {
                "subsurface_id": {
                  "type": "string",
                  "minLength": 1
                },
                "why": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "remaining_non_resumable_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "quality",
          "repair_step",
          "still_stale_parts",
          "stale_subsurfaces"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "quality": {
            "const": "NON_RESUMABLE"
          },
          "repair_step": {
            "type": "string",
            "minLength": 1
          },
          "still_stale_parts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stale_subsurfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "subsurface_id",
                "why"
              ],
              "properties": {
                "subsurface_id": {
                  "type": "string",
                  "minLength": 1
                },
                "why": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "next_step_id": {
      "type": "string"
    },
    "ready_now_step_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repair_history": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applied",
        "completed_step_ids",
        "last_completed_step_id",
        "current_step_id",
        "waiting_step_ids"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "completed_step_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "last_completed_step_id": {
          "type": "string"
        },
        "current_step_id": {
          "type": "string"
        },
        "waiting_step_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "resumability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "family"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "REPAIRABLE",
            "NOT_RESUMABLE"
          ]
        },
        "family": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "why": {
      "type": "string",
      "minLength": 1
    }
  }
}
