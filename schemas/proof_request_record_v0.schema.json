{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_class",
    "task_identity",
    "summary",
    "starter_mode",
    "starter_hashes",
    "preferred_artifacts",
    "required_sections",
    "next_safe_step"
  ],
  "properties": {
    "schema_version": {"const": "proof_request_record_v0"},
    "run_id": {"type": "string", "minLength": 1},
    "task_class": {"type": "string", "minLength": 1},
    "task_identity": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "starter_mode": {"const": "edit_in_place"},
    "starter_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final_result", "readback", "scenario_proof"],
      "properties": {
        "final_result": {"type": "string", "minLength": 64, "maxLength": 64},
        "readback": {"type": "string", "minLength": 64, "maxLength": 64},
        "scenario_proof": {"type": "string", "minLength": 64, "maxLength": 64}
      }
    },
    "preferred_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final_result", "readback", "scenario_proof"],
      "properties": {
        "final_result": {"type": "string", "minLength": 1},
        "readback": {"type": "string", "minLength": 1},
        "scenario_proof": {"type": "string", "minLength": 1}
      }
    },
    "required_sections": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "next_safe_step": {"type": "string", "minLength": 1}
  }
}
