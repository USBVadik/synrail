{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synrail.local/schemas/baseline_comparison_record_v1.schema.json",
  "title": "Synrail Baseline Comparison Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "scenario_class",
    "task_class",
    "baseline_path",
    "synrail_path",
    "baseline",
    "synrail",
    "economics_summary",
    "verdict",
    "why_verdict",
    "reasons"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "baseline_comparison_record_v1"
    },
    "scenario_id": {
      "type": "string"
    },
    "scenario_class": {
      "type": "string"
    },
    "task_class": {
      "type": "string"
    },
    "baseline_path": {
      "type": "string"
    },
    "synrail_path": {
      "type": "string"
    },
    "baseline": {
      "type": "object"
    },
    "synrail": {
      "type": "object"
    },
    "economics_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_minutes_added",
        "intervention_count_added",
        "repair_cycles_added",
        "invalidation_count_added",
        "closure_latency_minutes_added",
        "blocker_to_closure_cycles_added",
        "false_green_exposure_reduced",
        "artifact_completeness_percent_gain",
        "mandatory_mental_steps_added",
        "trust_bearing_artifacts_added",
        "required_visible_surfaces_added",
        "skippable_visible_surfaces_added",
        "fixed_control_mass_added"
      ],
      "properties": {
        "operator_minutes_added": {
          "type": "integer"
        },
        "intervention_count_added": {
          "type": "integer"
        },
        "repair_cycles_added": {
          "type": "integer"
        },
        "invalidation_count_added": {
          "type": "integer"
        },
        "closure_latency_minutes_added": {
          "type": "integer"
        },
        "blocker_to_closure_cycles_added": {
          "type": "integer"
        },
        "false_green_exposure_reduced": {
          "type": "integer"
        },
        "artifact_completeness_percent_gain": {
          "type": "integer"
        },
        "mandatory_mental_steps_added": {
          "type": "integer"
        },
        "trust_bearing_artifacts_added": {
          "type": "integer"
        },
        "required_visible_surfaces_added": {
          "type": "integer"
        },
        "skippable_visible_surfaces_added": {
          "type": "integer"
        },
        "fixed_control_mass_added": {
          "type": "integer"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["SYNRAIL_BETTER", "BASELINE_GOOD_ENOUGH", "UNCLEAR"]
    },
    "why_verdict": {
      "type": "string"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
