    "mode",
    "run_id",
    "task_class",
    "outcome_class",
    "summary",
    "diagnosis",
    "next_step",
    "restore_available",
    "checkpoint_id",
    "recovery_primary_action",
    "recovery_operator_instructions",
    "suggested_command",
    "technical_lines"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "thin_output_record_v0"},
