    "run_id": {"type": "string", "minLength": 1},
    "task_class": {"type": "string", "minLength": 1},
    "outcome_class": {"type": "string", "enum": ["NON_RESUMABLE", "CLOSURE_REJECTED", "PROOF_INVALID", "PROOF_PARTIAL", "REPAIR_STOP", "SCOPE_VIOLATION", "DOCTOR_BLOCKED", "NON_GREEN"]},
    "summary": {"type": "string", "minLength": 1},
    "diagnosis": {"type": "string", "minLength": 1},
    "next_step": {"type": "string", "minLength": 1},
    "restore_available": {"type": "boolean"},
    "checkpoint_id": {"type": "string"},
    "recovery_primary_action": {"type": "string"},
    "recovery_operator_instructions": {"type": "array", "items": {"type": "string"}},
    "suggested_command": {"type": "string", "minLength": 1},
    "technical_lines": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
