{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synrail.local/schemas/doctor_coverage_record_v0.schema.json",
  "title": "Synrail Doctor Coverage Record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "doctor_version",
    "coverage_source",
    "corpus_version",
    "coverage_threshold_policy",
    "critical_fail_modes",
    "declared_covered_fail_modes",
    "declared_partial_fail_modes",
    "declared_uncovered_fail_modes",
    "covered_fail_modes",
    "partial_fail_modes",
    "uncovered_fail_modes",
    "measured_case_count",
    "measured_case_match_count",
    "measured_case_problem_count",
    "measured_cases",
    "decision_trace",
    "critical_fail_mode_count",
    "critical_covered_count",
    "critical_missing_fail_modes",
    "critical_modes_without_measured_evidence",
    "critical_modes_with_mismatched_evidence",
    "deployment_context_confirmed",
    "threshold_met",
    "gate_status",
    "gate_reason"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "doctor_coverage_record_v0"},
    "doctor_version": {"type": "string", "minLength": 1},
    "coverage_source": {"type": "string", "minLength": 1},
    "corpus_version": {"type": "string", "minLength": 1},
    "coverage_threshold_policy": {"type": "string", "minLength": 1},
    "critical_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "declared_covered_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "declared_partial_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "declared_uncovered_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "covered_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "partial_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "uncovered_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "measured_case_count": {"type": "integer", "minimum": 0},
    "measured_case_match_count": {"type": "integer", "minimum": 0},
    "measured_case_problem_count": {"type": "integer", "minimum": 0},
    "measured_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "fail_mode_id",
          "doctor_record",
          "status",
          "observed_final_verdict",
          "observed_blocking_failure_classes",
          "observed_failing_gate",
          "observed_gate_note",
          "mismatch_reasons"
        ],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "fail_mode_id": {"type": "string", "minLength": 1},
          "doctor_record": {"type": "string", "minLength": 1},
          "status": {
            "type": "string",
            "enum": ["MATCHED", "MISMATCHED", "MISSING_EVIDENCE", "INVALID_EVIDENCE"]
          },
          "observed_final_verdict": {"type": "string"},
          "observed_blocking_failure_classes": {"type": "array", "items": {"type": "string"}},
          "observed_failing_gate": {"type": "string"},
          "observed_gate_note": {"type": "string"},
          "mismatch_reasons": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "decision_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fail_mode_id",
          "is_critical",
          "classification",
          "measured_case_ids",
          "matched_case_ids",
          "problematic_case_ids",
          "gate_effect",
          "why"
        ],
        "properties": {
          "fail_mode_id": {"type": "string", "minLength": 1},
          "is_critical": {"type": "boolean"},
          "classification": {"type": "string", "enum": ["COVERED", "PARTIAL", "UNCOVERED"]},
          "measured_case_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "matched_case_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "problematic_case_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "gate_effect": {
            "type": "string",
            "enum": [
              "SATISFIES_CRITICAL_COVERAGE",
              "HAS_MISMATCHED_EVIDENCE",
              "MISSING_MEASURED_EVIDENCE",
              "NON_CRITICAL"
            ]
          },
          "why": {"type": "string", "minLength": 1}
        }
      }
    },
    "critical_fail_mode_count": {"type": "integer", "minimum": 0},
    "critical_covered_count": {"type": "integer", "minimum": 0},
    "critical_missing_fail_modes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "critical_modes_without_measured_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "critical_modes_with_mismatched_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "deployment_context_confirmed": {"type": "boolean"},
    "threshold_met": {"type": "boolean"},
    "gate_status": {"type": "string", "enum": ["PASS", "BLOCKED"]},
    "gate_reason": {"type": "string", "minLength": 1}
  }
}
