{
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "task_class",
    "state",
    "result",
    "reason",
    "component_error_class",
    "next_safe_step",
    "acceptance_summary",
    "doctor_summary",
    "continuation_summary",
    "thin_output_summary",
    "observability_summary",
    "artifact_inventory",
    "issue_title",
    "issue_body"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "bug_packet_record_v0"},
    "run_id": {"type": "string", "minLength": 1},
    "task_class": {"type": "string", "minLength": 1},
    "state": {"type": "string", "minLength": 1},
    "result": {"type": "string"},
    "reason": {"type": "string"},
    "component_error_class": {"type": "string"},
    "next_safe_step": {"type": "string"},
    "acceptance_summary": {
      "type": "object",
      "required": ["criteria_revision_id", "status", "reason"],
      "properties": {
        "criteria_revision_id": {"type": "string"},
        "status": {"type": "string"},
        "reason": {"type": "string"}
      },
      "additionalProperties": false
    },
    "doctor_summary": {
      "type": "object",
      "required": ["final_verdict", "blocking_failure_classes", "coverage_gate_status", "coverage_gate_reason", "critical_missing_fail_modes"],
      "properties": {
        "final_verdict": {"type": "string"},
        "blocking_failure_classes": {"type": "array", "items": {"type": "string"}},
        "coverage_gate_status": {"type": "string"},
        "coverage_gate_reason": {"type": "string"},
        "critical_missing_fail_modes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "continuation_summary": {
      "type": "object",
      "required": ["entry_artifacts", "source_of_truth_precedence", "packet_replay_ready", "current_step_id", "current_step_subsurface_id", "current_step_target_path", "repair_family", "missing_inputs"],
      "properties": {
        "entry_artifacts": {"type": "array", "items": {"type": "string"}},
        "source_of_truth_precedence": {"type": "array", "items": {"type": "string"}},
        "packet_replay_ready": {"type": "boolean"},
        "current_step_id": {"type": "string"},
        "current_step_subsurface_id": {"type": "string"},
        "current_step_target_path": {"type": "string"},
        "repair_family": {"type": "string"},
        "missing_inputs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "thin_output_summary": {
      "type": "object",
      "required": ["outcome_class", "status_label", "what_happened", "what_to_do_next", "next_command", "restore_command"],
      "properties": {
        "outcome_class": {"type": "string"},
        "status_label": {"type": "string"},
        "what_happened": {"type": "string"},
        "what_to_do_next": {"type": "string"},
        "next_command": {"type": "string"},
        "restore_command": {"type": "string"}
      },
      "additionalProperties": false
    },
    "observability_summary": {
      "type": "object",
      "required": ["transition_count", "repair_attempt_count", "rejection_count", "latest_rejection"],
      "properties": {
        "transition_count": {"type": "integer", "minimum": 0},
        "repair_attempt_count": {"type": "integer", "minimum": 0},
        "rejection_count": {"type": "integer", "minimum": 0},
        "latest_rejection": {"type": "object"}
      },
      "additionalProperties": false
    },
    "artifact_inventory": {
      "type": "object",
      "required": ["available_artifacts", "missing_artifacts"],
      "properties": {
        "available_artifacts": {"type": "array", "items": {"type": "string"}},
        "missing_artifacts": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "issue_title": {"type": "string", "minLength": 1},
    "issue_body": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
